# ClickUp Personal API Token (required)
# Generate at: ClickUp Settings > Apps > API Token
CLICKUP_API_TOKEN= 

# Team ID — auto-detected and cached on first use
CLICKUP_TEAM_ID= 

# User ID — auto-detected and cached on first use
CLICKUP_USER_ID= 

# Default list ID for task creation without specifying a list (optional)
CLICKUP_DEFAULT_LIST_ID= 